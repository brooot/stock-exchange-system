# Git
.git
.gitignore

# Node modules
node_modules
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Build outputs
# dist  # 注释掉，生产环境需要 dist 目录
build
.next

# Cache directories
.nx
.pnpm-store
.cache

# IDE
.vscode
.idea
*.swp
*.swo

# OS
.DS_Store
Thumbs.db

# Logs
logs
*.log

# Runtime data
pids
*.pid
*.seed
*.pid.lock

# Coverage directory used by tools like istanbul
coverage

# Environment files (except development)
.env
.env.local
.env.production
.env.test

# Documentation
*.md
README*
CHANGELOG*

# Test files
**/*.test.ts
**/*.test.js
**/*.spec.ts
**/*.spec.js
__tests__

# Docker files (avoid recursion)
Dockerfile*
docker-compose*
.dockerignore

# Scripts (not needed in container)
scripts

# Temporary files
tmp
temp