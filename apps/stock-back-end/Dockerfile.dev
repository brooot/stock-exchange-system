FROM docker.io/node:22.17.0-alpine

ENV HOST=0.0.0.0
ENV PORT=3001

WORKDIR /app

# 安装pnpm、NX CLI和nodemon
RUN npm install -g pnpm nx nodemon

# 复制根目录依赖文件
COPY package.json pnpm-lock.yaml nx.json ./
COPY apps/stock-back-end/project.json ./apps/stock-back-end/

# 安装依赖
RUN pnpm install

# 复制源代码和配置文件
COPY tsconfig.base.json ./
COPY apps/stock-back-end ./apps/stock-back-end

# 复制 Prisma schema
COPY prisma ./prisma

# 生成 Prisma Client
RUN npx prisma generate

# 创建dist目录确保它存在
RUN mkdir -p /app/dist/apps/stock-back-end

# 使用nodemon监听文件变化并自动重启
CMD ["nodemon", "--watch", "apps/stock-back-end/src", "--ext", "ts,js,json", "--exec", "nx build stock-back-end --configuration=development && node dist/apps/stock-back-end/main.js"]
