{
  "name": "stock-back-end",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "apps/stock-back-end/src",
  "projectType": "application",
  "tags": [],
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "options": {
        "command": "webpack-cli build",
        "args": [
          "--node-env=production"
        ]
      },
      "configurations": {
        "development": {
          "args": ["--node-env=development"]
        }
      }
    },
    "serve": {
      "continuous": true,
      "executor": "@nx/js:node",
      "defaultConfiguration": "development",
      "dependsOn": ["build"],
      "options": {
        "buildTarget": "stock-back-end:build",
        "runBuildTargetDependencies": false,
        "args": [
          "--inspect=0.0.0.0:9229"
        ]
      },
      "configurations": {
        "development": {
          "buildTarget": "stock-back-end:build:development",
          "watch": true
        },
        "production": {
          "buildTarget": "stock-back-end:build:production"
        }
      }
    },
    "test": {
      "options": {
        "passWithNoTests": true
      }
    },
    "docker-build": {
      "dependsOn": [
        "build"
      ],
      "command": "docker build -f apps/stock-back-end/Dockerfile.dev . -t stock-back-end"
    }
  }
}
