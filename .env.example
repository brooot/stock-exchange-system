# 数据库配置
DATABASE_HOST=postgres
DATABASE_PORT=5432
DATABASE_USERNAME=postgres
DATABASE_PASSWORD=your_password_here
DATABASE_NAME=stock_db
DATABASE_SYNC=true

# Prisma 数据库连接 URL
# 开发环境（本地）：使用 localhost
# 容器环境：使用 postgres（服务名）
DATABASE_URL="postgresql://postgres:your_password_here@localhost:5432/stock_db?schema=public"

# 应用配置
NODE_ENV=development
PORT=3001

# 注意：
# 1. 复制此文件为 .env 并填入实际值
# 2. 开发环境 DATABASE_URL 使用 localhost
# 3. 容器环境会自动使用 postgres 作为主机名
# 4. 生产环境需要设置 DATABASE_SYNC=false